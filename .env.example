ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-openai-...

# Analyst models
DISSENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DISSENT_OPENAI_MODEL=gpt-5.4-mini

# Debate cap (validated to 1..4 in current implementation)
DISSENT_MAX_ROUNDS=4

# Log each LLM call to stderr: step N/total, role, model, then short text preview (stdio MCP safe).
# DISSENT_VERBOSE_LLM=1

# Judge — default is Gemini when GEMINI_API_KEY (or DISSENT_JUDGE_GEMINI_API_KEY / GOOGLE_CLOUD_API_KEY) is set.
# AI Studio keys: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Judge’s Gemini model if DISSENT_JUDGE_MODEL is not set:
DISSENT_GOOGLE_MODEL=gemini-2.5-flash
# Optional explicit override for judge model (any backend):
# DISSENT_JUDGE_MODEL=
# DISSENT_JUDGE_GEMINI_API_KEY=
# GOOGLE_CLOUD_API_KEY=

# If DISSENT_JUDGE_BASE_URL is set, an OpenAI-compatible judge client is used (overrides Gemini key).
# You can also point this at Gemini manually:
#   https://generativelanguage.googleapis.com/v1beta/openai/
# Example local endpoints:
#   Ollama:   http://localhost:11434/v1
#   LM Studio http://localhost:1234/v1
#   vLLM      http://localhost:8000/v1
DISSENT_JUDGE_BASE_URL=
DISSENT_JUDGE_API_KEY=
